# Build/test outputs
/.tmp/
/jkdeps
/*.test
*.out
/cmd/kotlin-compiler-golang/out/
/cmd/jkdeps/jkdeps-mixed-graph.json

# Local/debug run artifacts
/kor-*.json
/kcg-acceptance.json
/jkdeps-graph/
/jkdeps-graph.*
/jkdeps-mixed-graph/
/jkdeps-mixed-graph.*
