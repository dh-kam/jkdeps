*.py[cod]

# Downloaded tool binaries and generated tool classes
/tools/*.jar
/tools/*.klib
/tools/.kcg-official-classes/

# ANTLR generator side outputs; generated Go parser sources are committed.
/internal/parsers/**/*.interp
/internal/parsers/**/*.tokens
